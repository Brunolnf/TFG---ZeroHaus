rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /usuarios/{uid} {
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    match /viviendas/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /informes/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /proyectos/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /tecnicos/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.uid || resource.data.uid == "");
    }

    // Lectura/actualización/borrado solo del destinatario.
    // Creación abierta a cualquier usuario autenticado: permite que un técnico
    // cree una notificación para su cliente y viceversa.
    match /notificaciones/{docId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null;
    }

    match /solicitudes/{docId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.uidCliente ||
         request.auth.uid == resource.data.tecnicoId);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.uidCliente ||
         request.auth.uid == resource.data.tecnicoId);
    }

    match /certificados/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /resenas/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.participantes;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantes;

      match /mensajes/{mensajeId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;
      }
    }

    match /ajustes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
